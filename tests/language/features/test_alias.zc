
struct Point {
    x: int;
    y: int;
}

alias MyIntPtr = int*;
alias MyInt = int;

fn process(val: MyInt) -> MyInt {
    return val + 1;
}

// Both declarations of the `BinOp` function alias are equivalent, otherwise the c compiler will raise a conflicting type declaration error
alias BinOp = fn(int, int) -> int;
alias BinOp = (fn(int, int) -> int); // Notice the grouping parenthesis is not mistaken for a tuple

// All declarations of `HigherOrderBinOp` aliases should be equivalent to one another.
// If there was compatibility difference between them, the generated c code would fail due to conflicting type declaration.
alias HigherOrderBinOp = fn(BinOp) -> BinOp;
alias HigherOrderBinOp = fn(fn*(int, int) -> int) -> BinOp;
alias HigherOrderBinOp = fn((fn*(int, int) -> int)) -> BinOp; // Notice the grouping parenthesis is not mistaken for a tuple
alias HigherOrderBinOp = fn(BinOp) -> fn*(int, int) -> int;
alias HigherOrderBinOp = fn(BinOp) -> (fn*(int, int) -> int); // Notice the grouping parenthesis is not mistaken for a tuple
alias HigherOrderBinOp = fn((((BinOp)))) -> fn*(int, int) -> int; // Notice the redundant grouping parenthesis on `BinOp` are not mistaken for a tuple

alias HigherOrderBinOpStruct = fn(BinOpStruct) -> BinOp;

struct BinOpStruct {
    op: BinOp;
    hoop: HigherOrderBinOp;
}

fn add(a: int, b: int) -> int {
    return a + b;
}

fn sub(a: int, b: int) -> int {
    return a - b;
}

// Use function alias as parameter type
fn compute1(op: BinOp, a: int, b: int) -> int {
    return op(a, b);
}

// Use function alias as a substitute for a pointer to a function signature
fn compute2(op: fn*(int, int) -> int, a: int, b: int) -> int {
    return op(a, b);
}

// A higher order identity function generator
fn compute3(op: BinOp) -> fn*(int, int) -> int {
    return op;
}

// A higher order identity function generator, returning a function pointer as an aliased type
fn compute4(op: BinOp) -> BinOp {
    return op;
}

// A higher order identity function generator that operates on the `BinOpStruct`, returning a function pointer as an aliased type
fn compute5(obj: BinOpStruct) -> BinOp {
	let hoop = obj.hoop;
    return hoop(obj.op);
}

// Generic struct for alias testing
struct Vec2<T> {
    x: T;
    y: T;
}

impl Vec2<T> {
  fn neg(self) -> Vec2<T> {
    return Vec2<T>{x: -self.x, y: -self.y};
  }
  fn add(self, rhs: Vec2<T>) -> Vec2<T> {
    return Vec2<T>{x: self.x + rhs.x, y: self.y + rhs.y};
  }
  static fn zero() -> Vec2<T> {
    return Vec2<T>{x: 0, y: 0};
  }
}

alias Vec2f = Vec2<f32>;
alias Vec2i = Vec2<int>;

test "alias basic" {
    let x: MyInt = 10;
    let ptr: MyIntPtr = &x;
    
    assert(x == 10, "Basic alias failed");
    assert(*ptr == 10, "Pointer alias failed");
    
    let res = process(x);
    assert(res == 11, "Function with alias arg failed");
}

test "alias struct" {
    let p: Point = Point{x: 0, y: 0};
    p.x = 100;
    p.y = 200;
    
    assert(p.x == 100, "Struct alias access failed");
}

test "alias generic struct" {
    let v = Vec2f{x: 1.5, y: 2.5};
    assert(v.x > 1.0, "Generic alias field access failed");
    assert(v.y > 2.0, "Generic alias field access failed");
    
    let vi = Vec2i{x: 10, y: 20};
    assert(vi.x == 10, "Generic int alias failed");
    assert(vi.y == 20, "Generic int alias failed");
}

test "alias fstring" {
    let v = Vec2f{x: 3.14, y: 6.28};
    // This tests that f-string interpolation correctly resolves the alias
    println "v.x = {v.x}, v.y = {v.y}";
}

test "alias function pointer" {
    let op: BinOp;
    op = add;
    assert(op(1, 2) == 3, "Function alias calling failed");

    // Test using a variable of a function alias type as a parameter for the compute function
    assert(compute1(op, 10, 3) == 13, "Function alias with named variable failed");
	assert(compute2(op, 10, 3) == 13, "Function alias with named variable failed for a function that only accepts function pointers");

    // Test using a named function as a parameter for functions that accept an alias to a function type, and a pointer to a function type
    assert(compute1(sub, 10, 3) == 7, "Function alias with named function failed");
	assert(compute2(sub, 10, 3) == 7, "Function alias with named function failed for a function that only accepts function pointers");

    // Test passing a lambda through a function alias parameter, and pointer to a function type
    assert(compute1((a, b) -> a * b, 6, 7) == 42, "Function alias with lambda failed");
	assert(compute2((a, b) -> a * b, 6, 7) == 42, "Function alias with lambda failed for a function that only accepts function pointers");

    // Test higher-order function that returns a function pointer
    let returned_op = compute3(add);
    assert(returned_op(1, 2) == 3, "Higher-order fn returning fn* failed");
    assert(compute3(sub)(10, 3) == 7, "Direct call on higher-order function's result failed");
    assert(compute4(add) == returned_op && compute4(add) == add, "Returned function pointer from aliased type differs from the original");
    assert(compute4(add)(10, 3) == 13, "Direct call on higher-order function's aliased result failed");

	let binop_struct = BinOpStruct{op: sub, hoop: compute3};
	let hoop: HigherOrderBinOp = binop_struct.hoop;
    // assert(binop_struct.hoop(binop_struct.op) == sub, "Dereferencing function pointer alias from struct failed"); // TODO?: Not permitted by c due to `implicit declaration of function`.
    assert(hoop(binop_struct.op) == sub, "Dereferencing function pointer alias from struct failed");
    assert(hoop(binop_struct.op)(10, 3) == 7, "Direct call on function pointer alias from struct failed");
    assert(compute5(binop_struct) == sub, "Reference to function pointer obtained indirectly through a struct containing a higher-order function mismatches from the original");
}

test "alias operator overloading" {
  let v = Vec2f{x: 1.0, y: 1.0};
  v = -v;  // Should call __neg
  assert(v.x == -1.0, "Unary operator generic alias failed");
  
  v += v;  // Should call __add (-1 + -1 = -2)
  assert(v.x == -2.0, "Compound assignment generic alias failed");

  // Control
  let v2 = Vec2<f32>{x: 1.0, y: 1.0};
  v2 = -v2;
  v2 += v2;
  assert(v2.x == -2.0, "Control generic operator overloading failed");
}


test "alias static methods" {
    let v1 = Vec2f::zero();
    assert(v1.x == 0.0, "Direct static call on alias failed");

    println "Static call in f-string: {Vec2f::zero().x}";

    let v2 = Vec2<f32>::zero();
    assert(v2.x == 0.0, "Direct static call on generic failed");
}
